# Environment variables for ClawMemory
# Copy this to .env and fill in values before deploying
# All variables are prefixed with CLAWMEMORY_

# Backend secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
CLAWMEMORY_SECRET_KEY=change-me-to-a-random-secret-key

# License server URL
CLAWMEMORY_LICENSE_SERVER_URL=https://license.yourdomain.com

# CORS origins (comma-separated, or * for all)
CLAWMEMORY_CORS_ORIGINS=["*"]

# Server
CLAWMEMORY_HOST=0.0.0.0
CLAWMEMORY_PORT=8765
