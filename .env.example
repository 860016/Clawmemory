# Environment variables for ClawMemory
# Copy this to .env and fill in values before deploying
# All variables are prefixed with OPENCLAW_ (e.g. OPENCLAW_DB_PATH)

# Database path (default: backend/data/openclaw.db)
# OPENCLAW_DB_PATH=/app/data/openclaw.db

# Backend secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
OPENCLAW_SECRET_KEY=change-me-to-a-random-secret-key

# OpenClaw Gateway (local instance address, default port 18789)
OPENCLAW_OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_OPENCLAW_API_KEY=

# License server URL
OPENCLAW_LICENSE_SERVER_URL=https://license.yourdomain.com

# CORS origins (comma-separated, or * for all)
OPENCLAW_CORS_ORIGINS=["*"]

# Server
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8765
