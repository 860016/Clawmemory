# ClawMemory Environment Variables
# Copy this to go-backend/.env and fill in values

# Server
HOST=0.0.0.0
PORT=8765

# Backend secret key (generate with: openssl rand -base64 32)
SECRET_KEY=change-me-to-a-random-secret-key

# Data directory (optional, defaults to ./data next to executable)
# DATA_DIR=/path/to/data

# License server URL
LICENSE_SERVER_URL=https://auth.bestu.top
