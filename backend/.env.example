# ClawMemory 环境配置

# ===== 必须修改 =====
OPENCLAW_SECRET_KEY=change-me-in-production

# ===== 授权服务器 =====
OPENCLAW_LICENSE_SERVER_URL=https://auth.bestu.top
OPENCLAW_RSA_PUBLIC_KEY_PATH=./keys/public.pem

# ===== 数据目录 =====
OPENCLAW_DATA_DIR=./data

# ===== 服务配置 =====
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8765
OPENCLAW_DEBUG=false

# ===== CORS =====
OPENCLAW_CORS_ORIGINS=["*"]

# ===== 可选 =====
# OPENCLAW_CHROMA_PATH=./data/chroma

# ===== OpenClaw Gateway (聊天功能必须) =====
# OpenClaw 网关地址，聊天功能通过此地址与 OpenClaw 通信
OPENCLAW_OPENCLAW_GATEWAY_URL=http://localhost:8080
# OpenClaw API Key (如果 OpenClaw 网关需要认证)
OPENCLAW_OPENCLAW_API_KEY=
