# ClawMemory 环境配置

# ===== 必须修改 =====
CLAWMEMORY_SECRET_KEY=change-me-in-production

# ===== 授权服务器 =====
CLAWMEMORY_LICENSE_SERVER_URL=https://auth.bestu.top
CLAWMEMORY_RSA_PUBLIC_KEY_PATH=./keys/public.pem

# ===== 数据目录 =====
CLAWMEMORY_DATA_DIR=./data

# ===== 服务配置 =====
CLAWMEMORY_HOST=0.0.0.0
CLAWMEMORY_PORT=8765
CLAWMEMORY_DEBUG=false

# ===== CORS =====
CLAWMEMORY_CORS_ORIGINS=["*"]

# ===== 可选 =====
# CLAWMEMORY_CHROMA_PATH=./data/chroma
